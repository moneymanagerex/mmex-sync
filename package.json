{
  "name": "mmex-sync",
  "version": "1.0.0",
  "description": "A non-intrusive, \"Offline-First\" synchronization system for Money Manager Ex (MMEX) with PocketBase as backend.",
  "main": "sync.js",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "prebuild:windows": "npm run test",
    "build:windows": "powershell -ExecutionPolicy Bypass -File ./build.ps1",
    "prebuild:linux": "npm run test",
    "build:linux": "bash ./build_linux.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "enquirer": "^2.4.1",
    "eventsource": "^4.1.0",
    "pocketbase": "^0.26.8"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "jest": "^30.4.2",
    "rcedit": "^5.0.2"
  }
}