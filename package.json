{
  "name": "mmex-sync",
  "version": "0.1.4",
  "description": "A non-intrusive, \"Offline-First\" synchronization system for Money Manager Ex (MMEX) with PocketBase as backend.",
  "main": "src/index.js",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    
    "prebuild": "npm run test",
    
    "build:win": "node build.js --os=win", 
    "build:linux": "node build.js --os=linux",
    
    "package:win": "node package-dist.js --os=win",
    "package:linux": "node package-dist.js --os=linux",
    
    "release:win": "npm run build:win && npm run package:win",
    "release:linux": "npm run build:linux && npm run package:linux"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bin": {
    "mmex-sync": "./src/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "enquirer": "^2.4.1",
    "eventsource": "^4.1.0",
    "pocketbase": "^0.26.8"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "jest": "^30.4.2",
    "rcedit": "^5.0.2",
    "archiver": "^7.0.1"
  }
}