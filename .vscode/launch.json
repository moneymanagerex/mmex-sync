{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}\\src\\index.js"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "profile sample1",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}\\src\\index.js",
            "args": [
                "--verbose",
                "--profile=sample1",
                "--force"
                //                "--user=test.mmex@prudenzano.org",
                //                "--pbUrl=https://mmex-sync.prudenzano.org",
                //                "--pass=testami!"
            ]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "profile uat_dest",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}\\src\\index.js",
            "args": [
                "--profile=uat_dest"
            ]
        },
        {
            "type": "node-terminal",
            "name": "Run Script: test",
            "request": "launch",
            "command": "npm run test",
            "cwd": "${workspaceFolder}"
        }
    ]
}